{
  "collectionName": "components_shared_sliders",
  "info": {
    "displayName": "Slider",
    "icon": "address-book",
    "description": "Image slider with size options and preview functionality"
  },
  "options": {},
  "attributes": {
    "files": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "size": {
      "type": "enumeration",
      "enum": ["small", "medium", "large"],
      "default": "medium",
      "required": false
    },
    "alignment": {
      "type": "enumeration",
      "enum": ["left", "center", "right"],
      "default": "center",
      "required": false
    },
    "showPreview": {
      "type": "boolean",
      "default": true,
      "required": false
    }
  }
}
